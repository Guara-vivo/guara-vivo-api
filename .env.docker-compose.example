DATABASE_URL=postgresql://postgres:replace-with-your-password@your-supabase-host:5432/postgres
APP_ENV=development
JWT_SECRET_KEY=replace-with-a-secure-random-secret
JWT_ACCESS_TOKEN_EXPIRE=3600
JWT_REFRESH_TOKEN_EXPIRE=2592000
JWT_ALGORITHM=HS256
RECORDS_CACHE_TTL_SECONDS=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_REQUEST_BODY_BYTES=10485760
MAX_UPLOAD_FILE_BYTES=5242880
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
SUPABASE_STORAGE_BUCKET=frontend-uploads
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbitmq_user
RABBITMQ_PASSWORD=replace-with-a-secure-password
RABBITMQ_DEFAULT_USER=rabbitmq_user
RABBITMQ_DEFAULT_PASS=replace-with-a-secure-password
QUEUE_NAME=guara-vermelho-inference
ERROR_QUEUE_NAME=guara-vermelho-inference-error

IA_API_URL=http://identifier:8000/guara-vermelho/inference
DEBUG_SAVE_IMAGES_DIR=/debug/worker-images

LOG_LEVEL=INFO
MAX_RETRIES=3
RABBITMQ_RECONNECT_SECONDS=5
DOWNLOAD_TIMEOUT_SECONDS=30
IA_TIMEOUT_SECONDS=60
ALLOWED_IMAGE_HOSTS=your-supabase-host.supabase.co
MAX_IMAGE_BYTES=10485760
RABBITMQ_HEARTBEAT_SECONDS=600
RABBITMQ_BLOCKED_CONNECTION_TIMEOUT_SECONDS=300
DEBUG_MAX_RUNS=20
